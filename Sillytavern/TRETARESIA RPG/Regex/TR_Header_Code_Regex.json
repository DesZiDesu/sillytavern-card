{
    "id": "73777731-53e2-497a-9f6f-7321be29624b",
    "scriptName": "TR Header (catbox code)",
    "findRegex": "/\\[TR_HEAD\\|(?!https?:\\/\\/)([^|\\]]+?)\\|(.*?)\\|(.*?)(?:\\|(#[0-9A-Fa-f]{3,8}))?\\]/g",
    "replaceString": "<div style=\"display:flex;align-items:center;gap:11px;padding:4px 0 10px;margin:8px 0 15px;border-bottom:2px solid #d6b458;border-image:linear-gradient(90deg,$4,rgba(214,180,88,.12)) 1;font-family:'Chakra Petch',sans-serif;\"><div style=\"width:5px;align-self:stretch;min-height:32px;flex-shrink:0;background:#d6b458;background:$4;border-radius:2px;\"></div><div style=\"width:50px;height:56px;flex-shrink:0;position:relative;display:grid;place-items:center;\"><div style=\"position:absolute;inset:0;clip-path:polygon(50% 0,100% 25%,100% 75%,50% 100%,0 75%,0 25%);background:linear-gradient(180deg,#f4dc93,#9c7d31);\"></div><img src=\"https://files.catbox.moe/$1\" onerror=\"this.style.display='none'\" style=\"position:absolute;inset:2px;width:calc(100% - 4px);height:calc(100% - 4px);clip-path:polygon(50% 0,100% 25%,100% 75%,50% 100%,0 75%,0 25%);object-fit:cover;display:block;\"/></div><div style=\"min-width:0;flex:1;display:flex;flex-direction:column;gap:4px;\"><div style=\"font-family:'Orbitron',sans-serif;font-weight:800;font-size:16px;letter-spacing:2px;line-height:1.15;color:#f4dc93;color:$4;word-break:break-word;\">$2</div><div style=\"font-size:10px;letter-spacing:1.5px;color:#9a8a5e;text-transform:uppercase;word-break:break-word;\">$3</div></div></div>",
    "trimStrings": [],
    "placement": [
        1,
        2
    ],
    "disabled": false,
    "markdownOnly": true,
    "promptOnly": false,
    "runOnEdit": true,
    "substituteRegex": 0,
    "minDepth": null,
    "maxDepth": null
}
