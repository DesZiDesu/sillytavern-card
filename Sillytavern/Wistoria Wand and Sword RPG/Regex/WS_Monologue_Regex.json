{
    "id": "ws-monologue",
    "scriptName": "WS Monologue",
    "findRegex": "/\\[THINK\\|(.*?)\\|(.*?)\\|([\\s\\S]*?)\\]/g",
    "replaceString": "<div style=\"width:100%;max-width:720px;margin:16px auto 6px;box-sizing:border-box;font-family:'Spectral','Bai Jamjuree','Georgia',serif;\"><div style=\"position:relative;background:linear-gradient(180deg,#1a1d26,#14171e);border:1px solid #2a2a20;border-left:2px solid $2;padding:12px 16px 13px;box-shadow:0 4px 12px rgba(0,0,0,.45);\"><span style=\"position:absolute;top:-8px;left:10px;max-width:calc(100% - 24px);background:$2;color:#fff;font-family:'Cinzel','Kanit',serif;font-size:8.5px;font-weight:700;letter-spacing:1.1px;padding:2px 7px 2px 7px;text-transform:uppercase;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.4;box-sizing:border-box;\">$1</span><div style=\"font-style:italic;font-size:13.5px;line-height:1.65;color:#c8ced8;word-wrap:break-word;\">$3</div></div></div>",
    "trimStrings": [],
    "placement": [
        1,
        2
    ],
    "disabled": false,
    "markdownOnly": true,
    "promptOnly": false,
    "runOnEdit": true,
    "substituteRegex": 0,
    "minDepth": null,
    "maxDepth": null
}