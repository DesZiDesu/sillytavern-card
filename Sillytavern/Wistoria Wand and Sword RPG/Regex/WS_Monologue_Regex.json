{
    "id": "ws-monologue",
    "scriptName": "WS Monologue",
    "findRegex": "/\\[THINK\\|(.*?)\\|(.*?)\\|([\\s\\S]*?)\\]/g",
    "replaceString": "<div style=\"width:100%;max-width:720px;margin:12px auto 6px;box-sizing:border-box;font-family:'Spectral','Bai Jamjuree','Georgia',serif;\"><div style=\"position:relative;background:linear-gradient(180deg,#1a1d26,#14171e);border:1px solid #2a2a20;border-left:2px solid $2;padding:12px 16px 13px;box-shadow:0 4px 12px rgba(0,0,0,.45);\"><div style=\"display:flex;align-items:center;gap:8px;margin-bottom:8px;\"><span style=\"width:6px;height:6px;background:$2;transform:rotate(45deg);flex-shrink:0;\"></span><span style=\"font-family:'Cinzel','Kanit',serif;font-size:9.5px;font-weight:600;letter-spacing:1.4px;color:$2;text-transform:uppercase;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">$1</span><span style=\"flex:1;height:0;border-top:1px dashed $2;opacity:.45;\"></span></div><div style=\"font-style:italic;font-size:13.5px;line-height:1.65;color:#c8ced8;word-wrap:break-word;\">$3</div></div></div>",
    "trimStrings": [],
    "placement": [
        1,
        2
    ],
    "disabled": false,
    "markdownOnly": true,
    "promptOnly": false,
    "runOnEdit": true,
    "substituteRegex": 0,
    "minDepth": null,
    "maxDepth": null
}