    "findRegex": "/\\[SKILL\\|(.*?)\\|(.*?)\\|(.*?)\\|(.*?)\\]/g",
    "replaceString": "```\n<!DOCTYPE html><html><head><meta charset=\"UTF-8\"/><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/><link href=\"https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700&family=Kanit:wght@400;500;600&family=Bai+Jamjuree:wght@400;500;600&display=swap\" rel=\"stylesheet\"/><style>*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}html,body{background:transparent}.bar{position:relative;display:flex;align-items:center;gap:12px;padding:10px 13px;background:linear-gradient(180deg,#141821,#0e1119);border:1px solid #2a2a20;border-left:3px solid $4;box-shadow:0 0 16px -5px $4,0 4px 12px rgba(0,0,0,.5);font-family:'Cinzel','Kanit',serif;}.bar::before{content:'';position:absolute;top:3px;left:3px;width:8px;height:8px;border-top:1px solid #cda64e;border-left:1px solid #cda64e}.bar::after{content:'';position:absolute;bottom:3px;right:3px;width:8px;height:8px;border-bottom:1px solid #cda64e;border-right:1px solid #cda64e}.dia{position:relative;width:30px;height:30px;flex-shrink:0;display:flex;align-items:center;justify-content:center;border:1px solid $4;transform:rotate(45deg);box-shadow:inset 0 0 8px -2px $4}.dia svg{width:15px;height:15px;transform:rotate(-45deg);stroke:$4;fill:none;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round}.mid{display:flex;flex-direction:column;gap:3px;min-width:0;flex:1}.nm{font-size:13px;font-weight:700;color:#f2ead4;letter-spacing:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.meta{display:flex;align-items:center;gap:7px;font-family:'Kanit',sans-serif}.el{font-size:9.5px;font-weight:600;letter-spacing:1px;color:$4;text-transform:uppercase}.sep{width:3px;height:3px;background:#8a6f33;transform:rotate(45deg)}.ti{font-size:9.5px;letter-spacing:1px;color:#8a6f33;text-transform:uppercase}.cast{font-family:'Cinzel',serif;font-size:8px;letter-spacing:2px;color:#5a5443;text-transform:uppercase;writing-mode:vertical-rl}</style></head><body><textarea id=\"elv\" style=\"display:none\">$2</textarea><div class=\"bar\"><span class=\"dia\"><svg id=\"ico\" viewBox=\"0 0 24 24\"></svg></span><div class=\"mid\"><span class=\"nm\">$1</span><span class=\"meta\"><span class=\"el\">$2</span><span class=\"sep\"></span><span class=\"ti\">$3</span></span></div><span class=\"cast\">CAST</span></div><script>(function(){var el=(document.getElementById('elv').value||'').toLowerCase();var R=[['sword|blade|wis|ดาบ|วิส', 'sword'], ['fire|flame|burn|ไฟ|เพลิง', 'flame'], ['ice|frost|water|snow|น้ำแข็ง|น้ำ', 'ice'], ['lightning|thunder|bolt|สายฟ้า|ฟ้าผ่า', 'bolt'], ['wind|gale|storm|air|ลม|พายุ', 'wind'], ['earth|stone|rock|golem|ดิน|หิน|โกเลม', 'earth'], ['light|holy|radian|แสง|ศักดิ์สิทธิ์', 'sun'], ['dark|shadow|void|มืด|เงา', 'moon'], ['fantasy|illusion|mirage|ลวงตา|มายา|ภาพลวง', 'eye']];var G={'sword': '<path d=\"M14.5 17.5 3 6V3h3l11.5 11.5\"/><path d=\"M13 19l6-6\"/><path d=\"M16 16l4 4\"/><path d=\"M19 21l2-2\"/>', 'flame': '<path d=\"M12 2C9 6 7 8 7 12a5 5 0 0 0 10 0c0-3-2-4-2-7-2 2-3 2-3 0 0-1 0-2 0-3z\"/>', 'ice': '<path d=\"M12 2v20M4 7l16 10M20 7 4 17\"/><path d=\"M9.5 3.5 12 5l2.5-1.5M9.5 20.5 12 19l2.5 1.5\"/>', 'bolt': '<path d=\"M13 2 4 14h6l-1 8 9-12h-6z\"/>', 'wind': '<path d=\"M3 8h10a3 3 0 1 0-3-3M3 12h14a3 3 0 1 1-3 3M3 16h8\"/>', 'earth': '<path d=\"M3 20l5.5-9 3.5 4.5 3-4 6 8.5z\"/><circle cx=\"8\" cy=\"8\" r=\"1.6\"/>', 'sun': '<circle cx=\"12\" cy=\"12\" r=\"4\"/><path d=\"M12 2v3M12 19v3M2 12h3M19 12h3M5 5l2 2M17 17l2 2M19 5l-2 2M7 17l-2 2\"/>', 'moon': '<path d=\"M20 14.5A8 8 0 1 1 10.5 4 6.4 6.4 0 0 0 20 14.5z\"/>', 'eye': '<path d=\"M2 12s4-7 10-7 10 7 10 7-4 7-10 7-10-7-10-7z\"/><circle cx=\"12\" cy=\"12\" r=\"2.4\"/>', 'star': '<path d=\"M12 2l2.2 6.2L20 9l-5.2 2.4L12 18l-2.8-6.6L4 9z\"/>'};var key='star';for(var i=0;i<R.length;i++){if(new RegExp(R[i][0]).test(el)){key=R[i][1];break;}}document.getElementById('ico').innerHTML=G[key];})();</script></body></html>\n```",
