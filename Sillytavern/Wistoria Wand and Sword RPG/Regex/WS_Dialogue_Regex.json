{
    "id": "ws-dialogue",
    "scriptName": "WS Dialogue",
    "findRegex": "/\\[SAY\\|(.*?)\\|([\\s\\S]*?)\\]/g",
    "replaceString": "<div style=\"max-width:480px;margin:8px auto;font-family:'Spectral','Bai Jamjuree',serif;\"><div style=\"position:relative;background:linear-gradient(180deg,#f5ecd5,#ece0c3);color:#241c0e;border:1px solid $1;padding:13px 20px;font-size:14.5px;font-weight:500;line-height:1.6;box-shadow:0 5px 16px rgba(0,0,0,.5),inset 0 0 0 1px rgba(205,166,78,.35);\"><span style=\"position:absolute;top:5px;left:7px;width:8px;height:8px;border-top:1px solid $1;border-left:1px solid $1;\"></span><span style=\"position:absolute;bottom:5px;right:7px;width:8px;height:8px;border-bottom:1px solid $1;border-right:1px solid $1;\"></span><span style=\"position:absolute;top:-7px;left:30px;width:13px;height:13px;background:#f5ecd5;border-left:1px solid $1;border-top:1px solid $1;transform:rotate(45deg);\"></span>$2</div></div>",
    "trimStrings": [],
    "placement": [
        1,
        2
    ],
    "disabled": false,
    "markdownOnly": true,
    "promptOnly": false,
    "runOnEdit": true,
    "substituteRegex": 0,
    "minDepth": null,
    "maxDepth": null
}