{
    "id": "ws-character-header",
    "scriptName": "WS Character Header",
    "findRegex": "/\\[CHAR\\|(.*?)\\|(.*?)\\|(.*?)\\]/g",
    "replaceString": "<div style=\"box-sizing:border-box;width:100%;max-width:720px;margin:0 auto;display:flex;align-items:stretch;gap:0;font-family:'Cinzel','Kanit',serif;background:#0e1119;border:1px solid #2a2a20;border-left:3px solid $3;\"><div style=\"position:relative;width:54px;height:54px;flex-shrink:0;background:#10131a;border-right:1px solid #2a2a20;overflow:hidden;display:flex;align-items:center;justify-content:center;\"><span style=\"position:absolute;top:0;left:0;right:0;height:2px;background:$3;z-index:2;\"></span><svg viewBox=\"0 0 24 24\" style=\"width:55%;height:55%;stroke:#4a4636;fill:none;stroke-width:1.4;position:absolute;left:50%;top:52%;transform:translate(-50%,-50%);z-index:0\"><circle cx=\"12\" cy=\"8\" r=\"4\"/><path d=\"M4 21a8 8 0 0 1 16 0\"/></svg><img src=\"$1\" style=\"width:100%;height:100%;object-fit:cover;position:relative;z-index:1\" onerror=\"if(this.dataset.cb){this.style.display='none'}else{this.dataset.cb=1;this.src='https://files.catbox.moe/$1'}\"/></div><div style=\"display:flex;flex-direction:column;justify-content:center;gap:4px;padding:8px 13px;min-width:0;flex:1;\"><span style=\"display:flex;align-items:center;gap:7px;\"><span style=\"width:7px;height:7px;background:$3;transform:rotate(45deg);flex-shrink:0;box-shadow:0 0 6px $3;\"></span><span style=\"font-size:13px;font-weight:600;color:#ece3cf;letter-spacing:1.5px;text-transform:uppercase;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">$2</span></span><span style=\"display:block;height:1px;background:$3;opacity:.7;\"></span><span style=\"display:block;height:1px;background:rgba(205,166,78,.35);\"></span></div></div>",
    "trimStrings": [],
    "placement": [
        1,
        2
    ],
    "disabled": false,
    "markdownOnly": true,
    "promptOnly": false,
    "runOnEdit": true,
    "substituteRegex": 0,
    "minDepth": null,
    "maxDepth": 2
}