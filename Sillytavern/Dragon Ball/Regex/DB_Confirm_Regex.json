 "replaceString": "```\n<!DOCTYPE html><html><head><meta charset=\"UTF-8\"/><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Rajdhani:wght@500;600;700&family=Share+Tech+Mono&display=swap\" rel=\"stylesheet\"/>\n<style>\n*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}html,body{background:transparent;-webkit-tap-highlight-color:transparent}body{padding:10px 5px;font-family:'Rajdhani',system-ui,sans-serif;color:#e8eaee}.dbd{max-width:560px;margin:0 auto;background:linear-gradient(165deg,rgba(11,28,43,.9),rgba(7,14,23,.86));border:1px solid #17384f;overflow:hidden;box-shadow:0 18px 44px rgba(0,0,0,.5),0 0 0 1px rgba(41,211,255,.05);clip-path:polygon(0 0,100% 0,100% 97%,98.5% 100%,0 100%)}.top{display:flex;align-items:center;gap:11px;background:linear-gradient(120deg,#0e2233,#0a1826);color:#edf4f4;padding:12px 13px;border-bottom:1px solid #143047}.ball{position:relative;width:36px;height:36px;flex:0 0 36px;border-radius:50%;background:radial-gradient(circle at 30% 24%,#ffe27a 0 16%,#ffb232 35%,#f28a16 70%,#c9580c 100%);box-shadow:inset -4px -5px 10px rgba(99,35,0,.35),0 0 0 1px rgba(255,198,84,.35),0 0 14px rgba(245,140,22,.4)}.ball:before{content:\"\";position:absolute;left:50%;top:50%;width:14px;height:14px;transform:translate(-50%,-50%);background:#cf1f17;clip-path:polygon(50% 0,61% 34%,98% 35%,68% 56%,79% 91%,50% 70%,21% 91%,32% 56%,2% 35%,39% 34%)}.h{min-width:0;flex:1}.name{font:700 19px 'Saira Condensed','Oswald',sans-serif;letter-spacing:.05em;text-transform:uppercase;color:#dff2ff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.sub{font:700 8px 'Share Tech Mono',monospace;letter-spacing:.13em;text-transform:uppercase;color:#4f7188;margin-top:3px}.seal{font:700 9px 'Oswald',sans-serif;letter-spacing:.13em;text-transform:uppercase;color:#04121c;background:linear-gradient(180deg,#67e88d,#2eb95d);padding:6px 10px;white-space:nowrap;clip-path:polygon(10% 0,100% 0,90% 100%,0 100%);box-shadow:0 0 12px rgba(46,185,93,.3)}.body{padding:12px}.sec{margin:0 0 11px}.sh{display:flex;align-items:center;gap:8px;margin:12px 0 8px}.sh:first-child{margin-top:0}.sh b{font:700 10px 'Oswald',sans-serif;letter-spacing:.16em;text-transform:uppercase;color:#29d3ff}.sh span{height:1px;flex:1;background:linear-gradient(90deg,rgba(41,211,255,.4),transparent)}.grid{display:grid;grid-template-columns:1fr 1fr;gap:6px}.cell{background:rgba(4,18,28,.6);border:1px solid #143047;padding:7px 9px;min-width:0;clip-path:polygon(0 0,100% 0,100% 78%,95% 100%,0 100%)}.cell.w{grid-column:1/-1}.k{display:block;font:700 7px 'Share Tech Mono',monospace;letter-spacing:.14em;text-transform:uppercase;color:#4f7188;margin-bottom:3px}.v{display:block;font:600 12.5px 'Rajdhani',sans-serif;color:#dff2ff;line-height:1.3;white-space:pre-wrap;overflow-wrap:anywhere}.v em{font-style:normal;color:#ff8a1e}.tags{display:flex;flex-wrap:wrap;gap:5px}.tag{border:1px solid #1c5a7a;background:rgba(41,211,255,.09);color:#cfeaff;padding:5px 8px;font:700 11px 'Rajdhani',sans-serif;clip-path:polygon(8% 0,100% 0,92% 100%,0 100%)}.aura{display:inline-block;width:11px;height:11px;border-radius:50%;border:1px solid rgba(255,255,255,.25);vertical-align:-1px;margin-right:5px}.foot{border-top:1px dashed #143047;padding:9px 11px;color:#4f7188;font:700 9px 'Share Tech Mono',monospace;letter-spacing:.12em;text-transform:uppercase;text-align:center}@media(max-width:460px){body{padding:8px 4px}.grid{grid-template-columns:1fr}.cell.w{grid-column:auto}.name{font-size:16px}.seal{display:none}}\n</style></head><body>\n<textarea id=\"raw\" style=\"display:none\">$1</textarea><div class=\"dbd\"><div class=\"top\"><div class=\"ball\"></div><div class=\"h\"><div class=\"name\" id=\"name\">Fighter</div><div class=\"sub\" id=\"subtitle\">Dragon Ball Character Creation</div></div><div class=\"seal\" id=\"seal\">CONFIRMED</div></div><div class=\"body\" id=\"body\"></div><div class=\"foot\" id=\"foot\">DB_CONFIRM received</div></div>\n<script>\n(function(){function g(i){return document.getElementById(i)}function esc(s){return String(s==null?'':s).replace(/&(?!(amp|lt|gt|#\\d+);)/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}function has(v){return v!=null&&String(v).trim()!==''}function arr(v){if(v==null)return[];return Array.isArray(v)?v.filter(function(x){return has(x)}):String(v).split(/[,;]+/).map(function(x){return x.trim()}).filter(Boolean)}function val(v){return has(v)?esc(v):'--'}function tags(a){a=arr(a);return a.length?'<div class=\"tags\">'+a.map(function(x){return '<span class=\"tag\">'+esc(x)+'</span>'}).join('')+'</div>':'<span class=\"v\">--</span>'}function cell(k,v,w,raw){return '<div class=\"cell'+(w?' w':'')+'\"><span class=\"k\">'+esc(k)+'</span><span class=\"v\">'+(raw?v:val(v))+'</span></div>'}function sec(t,html){return '<div class=\"sec\"><div class=\"sh\"><b>'+esc(t)+'</b><span></span></div>'+html+'</div>'}var raw=(g('raw').value||'').replace(/<\\/?DB_CONFIRM>/gi,'').trim();var d={};try{d=JSON.parse(raw)}catch(e){}g('name').textContent=d.name||'Unnamed Fighter';g('subtitle').textContent=((d.race_family||'No race selected')+(d.race_subtype?' - '+d.race_subtype:''));var aura=esc(d.aura_color||'#F59B22');var h='';h+=sec('Identity','<div class=\"grid\">'+cell('Pronouns',d.pronouns)+cell('Age',d.age)+cell('Aura','<span class=\"aura\" style=\"background:'+aura+'\"></span>'+aura,false,true)+cell('Personality',d.personality,true)+'</div>');var ap=d.appearance||{};h+=sec('Appearance','<div class=\"grid\">'+cell('Height',ap.height)+cell('Build',ap.build)+cell('Hair',ap.hair)+cell('Eyes',ap.eyes)+cell('Skin',ap.skin,true)+cell('Features',ap.features,true)+cell('Attire',ap.attire,true)+'</div>');h+=sec('Origin','<div class=\"grid\">'+cell('Era',d.era)+cell('Home',d.home)+cell('Origin Notes',d.origin_notes,true)+'</div>');h+=sec('Race','<div class=\"grid\">'+cell('Race Family','<em>'+val(d.race_family)+'</em>',false,true)+cell('Subtype',d.race_subtype)+cell('Source',d.race_source)+cell('Subtype Detail',d.subtype_detail,true)+cell('Race Abilities',tags(d.race_abilities),true,true)+'</div>');var cf=d.custom_form||{};h+=sec('Power','<div class=\"grid\">'+cell('Starting Power',d.starting_power)+cell('Growth Style',d.growth_style)+cell('Forms',tags(d.forms),true,true)+cell('Custom Form',(has(cf.name)||has(cf.detail))?((cf.name||'Custom Form')+(has(cf.detail)?' - '+cf.detail:'')):'',true)+'</div>');h+=sec('Loadout','<div class=\"grid\">'+cell('Techniques',tags(d.techniques),true,true)+cell('Gear',tags(d.gear),true,true)+cell('Custom Loadout',d.custom_loadout,true)+'</div>');h+=sec('Opening','<div class=\"grid\">'+cell('Opening Scene',d.opening_scene,true)+cell('Confirmation Style',d.confirm_style,true)+'</div>');g('body').innerHTML=h;g('foot').textContent='Dragon Ball character confirmed';})();\n</script></body></html>\n```",
