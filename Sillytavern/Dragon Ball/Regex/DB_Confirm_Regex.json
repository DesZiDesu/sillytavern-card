    "findRegex": "/<DB_CONFIRM>([\\s\\S]*?)<\\/DB_CONFIRM>/gm",
    "replaceString": "```\n<!DOCTYPE html><html><head><meta charset=\"UTF-8\"/><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Rajdhani:wght@500;600;700&family=Share+Tech+Mono&display=swap\" rel=\"stylesheet\"/>\n<style>\n*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}html,body{background:transparent;-webkit-tap-highlight-color:transparent}body{padding:12px 8px;font-family:'Rajdhani',system-ui,sans-serif;color:#1d2526}.dbd{max-width:560px;margin:0 auto;background:linear-gradient(180deg,#f4f1e7,#ded8c8);border:1px solid rgba(255,255,255,.65);border-radius:6px;overflow:hidden;box-shadow:0 18px 44px rgba(0,0,0,.42)}.top{display:flex;align-items:center;gap:10px;background:#202729;color:#edf4f4;padding:10px 12px}.ball{position:relative;width:34px;height:34px;flex:0 0 34px;border-radius:50%;background:radial-gradient(circle at 30% 24%,#ffe27a 0 16%,#ffb232 35%,#f28a16 70%,#c9580c 100%);box-shadow:inset -4px -5px 10px rgba(99,35,0,.35),0 0 0 1px rgba(255,198,84,.35)}.ball:before{content:\"\";position:absolute;left:50%;top:50%;width:13px;height:13px;transform:translate(-50%,-50%);background:#cf1f17;clip-path:polygon(50% 0,61% 34%,98% 35%,68% 56%,79% 91%,50% 70%,21% 91%,32% 56%,2% 35%,39% 34%)}.h{min-width:0;flex:1}.name{font:700 19px 'Oswald';letter-spacing:.08em;text-transform:uppercase;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.sub{font:700 8px 'Share Tech Mono';letter-spacing:.13em;text-transform:uppercase;color:#91a0a4;margin-top:2px}.seal{font:700 9px 'Oswald';letter-spacing:.13em;text-transform:uppercase;color:#08120d;background:linear-gradient(180deg,#67e88d,#2eb95d);border-radius:4px;padding:6px 9px;white-space:nowrap}.body{padding:11px}.sec{margin:0 0 10px}.sh{display:flex;align-items:center;gap:8px;margin:11px 0 7px}.sh:first-child{margin-top:0}.sh b{font:700 11px 'Oswald';letter-spacing:.14em;text-transform:uppercase;color:#1e2829}.sh span{height:1px;flex:1;background:#c8c3b7}.grid{display:grid;grid-template-columns:1fr 1fr;gap:6px}.cell{background:#fff;border:1px solid #cdd0c8;border-radius:4px;padding:7px 8px;min-width:0}.cell.w{grid-column:1/-1}.k{display:block;font:700 7px 'Share Tech Mono';letter-spacing:.14em;text-transform:uppercase;color:#818a86;margin-bottom:2px}.v{display:block;font:700 12.5px 'Rajdhani';color:#222c2c;line-height:1.25;white-space:pre-wrap;overflow-wrap:anywhere}.v em{font-style:normal;color:#dd7810}.tags{display:flex;flex-wrap:wrap;gap:5px}.tag{border:1px solid #d1b071;background:#fff8e5;color:#5b3a0c;border-radius:4px;padding:5px 8px;font:700 11.5px 'Rajdhani'}.aura{display:inline-block;width:10px;height:10px;border-radius:50%;border:1px solid rgba(0,0,0,.24);vertical-align:-1px;margin-right:5px}.foot{border-top:1px dashed #c8c3b7;padding:9px 11px;color:#6c716d;font:700 9px 'Share Tech Mono';letter-spacing:.12em;text-transform:uppercase;text-align:center}@media(max-width:460px){body{padding:8px 4px}.top{align-items:flex-start}.grid{grid-template-columns:1fr}.cell.w{grid-column:auto}.name{font-size:16px}.seal{display:none}}\n</style></head><body>\n<textarea id=\"raw\" style=\"display:none\">$1</textarea><div class=\"dbd\"><div class=\"top\"><div class=\"ball\"></div><div class=\"h\"><div class=\"name\" id=\"name\">Fighter</div><div class=\"sub\" id=\"subtitle\">Dragon Ball Character Creation</div></div><div class=\"seal\" id=\"seal\">CONFIRMED</div></div><div class=\"body\" id=\"body\"></div><div class=\"foot\" id=\"foot\">DB_CONFIRM received</div></div>\n<script>\n(function(){function g(i){return document.getElementById(i)}function esc(s){return String(s==null?'':s).replace(/&(?!(amp|lt|gt|#\\d+);)/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}function has(v){return v!=null&&String(v).trim()!==''}function arr(v){if(v==null)return[];return Array.isArray(v)?v.filter(function(x){return has(x)}):String(v).split(/[,;]+/).map(function(x){return x.trim()}).filter(Boolean)}function val(v){return has(v)?esc(v):'--'}function tags(a){a=arr(a);return a.length?'<div class=\"tags\">'+a.map(function(x){return '<span class=\"tag\">'+esc(x)+'</span>'}).join('')+'</div>':'<span class=\"v\">--</span>'}function cell(k,v,w,raw){return '<div class=\"cell'+(w?' w':'')+'\"><span class=\"k\">'+esc(k)+'</span><span class=\"v\">'+(raw?v:val(v))+'</span></div>'}function sec(t,html){return '<div class=\"sec\"><div class=\"sh\"><b>'+esc(t)+'</b><span></span></div>'+html+'</div>'}var raw=(g('raw').value||'').replace(/<\\/?DB_CONFIRM>/gi,'').trim();var d={};try{d=JSON.parse(raw)}catch(e){}g('name').textContent=d.name||'Unnamed Fighter';g('subtitle').textContent=((d.race_family||'No race selected')+(d.race_subtype?' - '+d.race_subtype:''));var aura=esc(d.aura_color||'#F59B22');var h='';h+=sec('Identity','<div class=\"grid\">'+cell('Pronouns',d.pronouns)+cell('Age',d.age)+cell('Aura','<span class=\"aura\" style=\"background:'+aura+'\"></span>'+aura,false,true)+cell('Personality',d.personality,true)+'</div>');h+=sec('Origin','<div class=\"grid\">'+cell('Era',d.era)+cell('Home',d.home)+cell('Origin Notes',d.origin_notes,true)+'</div>');h+=sec('Race','<div class=\"grid\">'+cell('Race Family','<em>'+val(d.race_family)+'</em>',false,true)+cell('Subtype',d.race_subtype)+cell('Source',d.race_source)+cell('Subtype Detail',d.subtype_detail,true)+cell('Race Abilities',tags(d.race_abilities),true,true)+'</div>');var cf=d.custom_form||{};h+=sec('Power','<div class=\"grid\">'+cell('Starting Power',d.starting_power)+cell('Growth Style',d.growth_style)+cell('Forms',tags(d.forms),true,true)+cell('Custom Form',(has(cf.name)||has(cf.detail))?((cf.name||'Custom Form')+(has(cf.detail)?' - '+cf.detail:'')):'',true)+'</div>');h+=sec('Loadout','<div class=\"grid\">'+cell('Techniques',tags(d.techniques),true,true)+cell('Gear',tags(d.gear),true,true)+cell('Custom Loadout',d.custom_loadout,true)+'</div>');h+=sec('Opening','<div class=\"grid\">'+cell('Opening Scene',d.opening_scene,true)+cell('Confirmation Style',d.confirm_style,true)+'</div>');g('body').innerHTML=h;g('foot').textContent='Dragon Ball character confirmed';})();\n</script></body></html>\n```",
