transform:uppercase;letter-spacing:.5px;\">Danger</span><div style=\"flex:1;height:8px;background:#211830;border-radius:5px;overflow:hidden;\"><div style=\"width:$9%;max-width:100%;height:100%;background:linear-gradient(90deg,#e05a5a,#ff9a9a);border-radius:5px;\"></div></div><span style=\"width:26px;text-align:right;font-size:11px;font-weight:600;color:#d6cee6;\">$9</span></div><div style=\"display:flex;align-items:center;gap:9px;margin-bottom:6px;\"><span style=\"width:70px;flex-shrink:0;font-size:11px;color:#a99fbb;text-transform:uppercase;letter-spacing:.5px;\">Courage</span><div style=\"flex:1;height:8px;background:#211830;border-radius:5px;overflow:hidden;\"><div style=\"width:$10%;max-width:100%;height:100%;background:linear-gradient(90deg,#b07de0,#d9b6f5);border-radius:5px;\"></div></div><span style=\"width:26px;text-align:right;font-size:11px;font-weight:600;color:#d6cee6;\">$10</span></div><div style=\"display:flex;align-items:center;gap:9px;margin-bottom:6px;\"><span style=\"width:70px;flex-shrink:0;font-size:11px;color:#a99fbb;text-transform:uppercase;letter-spacing:.5px;\">Bond</span><div style=\"flex:1;height:8px;background:#211830;border-radius:5px;overflow:hidden;\"><div style=\"width:$11%;max-width:100%;height:100%;background:linear-gradient(90deg,#e8557f,#ff8fb0);border-radius:5px;\"></div></div><span style=\"width:26px;text-align:right;font-size:11px;font-weight:600;color:#d6cee6;\">$11</span></div></div><div style=\"padding:2px 14px 12px 14px;font-size:11px;color:#8f82a3;border-top:1px solid #241a34;margin-top:2px;padding-top:9px;\">✎ <span style=\"color:#c4bad4;\">$12</span></div></details>",
