{"id": "sw-tracker", "scriptName": "SW Tracker", "findRegex": "/\\[TRACK\\|(.*?)\\|(.*?)\\|(.*?)\\|(.*?)\\|(.*?)\\|(.*?)\\|(.*?)\\|(.*?)\\|(.*?)\\|(.*?)\\]/g", "replaceString": "<link href=\"https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@500;700&family=Noto+Serif+JP:wght@500;700&family=Noto+Serif+Thai:wght@500;700&family=M+PLUS+1:wght@400;500;600&display=swap\" rel=\"stylesheet\"/><style>.trk{width:100%;max-width:480px;margin:0 auto 10px;font-family:'Shippori Mincho','Noto Serif JP','Noto Serif Thai',serif;position:relative}.trk-bar{background:linear-gradient(180deg,#f5ead5,#f0e0c8);border:1px solid #c4a882;border-radius:8px;padding:6px 12px;box-shadow:0 2px 8px rgba(0,0,0,.15);cursor:pointer;position:relative}.trk-top{display:flex;align-items:center;justify-content:space-between;gap:8px}.trk-loc{font-size:11px;color:#3a2a1a;font-weight:700;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.trk-time{font-size:10px;color:#8b4513;font-weight:600;white-space:nowrap}.trk-arc{font-family:'M PLUS 1',sans-serif;font-size:8px;color:#a08060;letter-spacing:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.trk-ck{display:flex;align-items:center;gap:4px;white-space:nowrap}.trk-ck-bar{width:40px;height:4px;background:#d4bc9a;border-radius:2px;overflow:hidden}.trk-ck-fill{height:100%;background:linear-gradient(90deg,#2e6b8a,#3a8aaa);border-radius:2px}.trk-ck-pct{font-family:'M PLUS 1',sans-serif;font-size:8px;color:#8b4513;font-weight:600}.trk-arrow{font-size:8px;color:#a08060;transition:transform .2s}.trk.open .trk-arrow{transform:rotate(180deg)}.trk-detail{display:none;padding:8px 0 2px;border-top:1px solid #d4bc9a;margin-top:6px}.trk.open .trk-detail{display:block}.trk-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px}.trk-cell{padding:4px 0}.trk-cl{font-family:'M PLUS 1',sans-serif;font-size:6px;letter-spacing:1.5px;color:#a08060}.trk-cv{font-size:10px;color:#3a2a1a;margin-top:1px}.trk-sit{padding:4px 0;border-top:1px solid #e8d5b8;margin-top:4px}.trk-sit .trk-cv{font-size:10px;color:#2a1e14;line-height:1.4}</style><div class=\"trk\" onclick=\"this.classList.toggle('open')\"><div class=\"trk-bar\"><div class=\"trk-top\"><div style=\"display:flex;align-items:center;gap:6px;flex:1;min-width:0\"><span class=\"trk-loc\">$6</span><span class=\"trk-arc\">$3</span></div><div style=\"display:flex;align-items:center;gap:8px\"><div class=\"trk-ck\"><div class=\"trk-ck-bar\"><div class=\"trk-ck-fill\" style=\"width:$4%\"></div></div><span class=\"trk-ck-pct\">$4%</span></div><span class=\"trk-time\">$2</span><span class=\"trk-arrow\">▼</span></div></div><div class=\"trk-detail\"><div class=\"trk-grid\"><div class=\"trk-cell\"><div class=\"trk-cl\">DATE</div><div class=\"trk-cv\">$1</div></div><div class=\"trk-cell\"><div class=\"trk-cl\">WEATHER</div><div class=\"trk-cv\">$7</div></div><div class=\"trk-cell\"><div class=\"trk-cl\">NATION</div><div class=\"trk-cv\">$5</div></div><div class=\"trk-cell\"><div class=\"trk-cl\">POSITION</div><div class=\"trk-cv\">$8</div></div></div><div class=\"trk-sit\"><div class=\"trk-cl\">STANCE</div><div class=\"trk-cv\">$9</div></div><div class=\"trk-sit\"><div class=\"trk-cl\">SITUATION</div><div class=\"trk-cv\">$10</div></div></div></div></div>", "trimStrings": [], "placement": [1, 2], "disabled": false, "markdownOnly": true, "promptOnly": false, "runOnEdit": true, "substituteRegex": 0, "minDepth": null, "maxDepth": null}