    "replaceString": "<link href=\"https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@500;700;800&family=Noto+Serif+JP:wght@500;700;900&family=Noto+Serif+Thai:wght@500;700&family=M+PLUS+1:wght@400;600;700&display=swap\" rel=\"stylesheet\"/><div style=\"max-width:480px;margin:14px auto 12px;font-family:'Shippori Mincho','Noto Serif JP','Noto Serif Thai',serif;\"><div style=\"display:flex;align-items:center;gap:14px;\"><div style=\"position:relative;width:58px;height:58px;flex-shrink:0;\"><span style=\"position:absolute;top:-8px;left:50%;transform:translateX(-50%);font-size:7px;color:$3;opacity:.25;font-family:'Noto Serif JP',serif;\">忍</span><span style=\"position:absolute;top:50%;right:-10px;transform:translateY(-50%);font-size:7px;color:$3;opacity:.25;font-family:'Noto Serif JP',serif;\">術</span><span style=\"position:absolute;bottom:-8px;left:50%;transform:translateX(-50%);font-size:7px;color:$3;opacity:.25;font-family:'Noto Serif JP',serif;\">火</span><span style=\"position:absolute;top:50%;left:-10px;transform:translateY(-50%);font-size:7px;color:$3;opacity:.25;font-family:'Noto Serif JP',serif;\">風</span><span style=\"position:absolute;top:1px;right:1px;font-size:6px;color:$3;opacity:.18;font-family:'Noto Serif JP',serif;\">体</span><span style=\"position:absolute;bottom:1px;right:1px;font-size:6px;color:$3;opacity:.18;font-family:'Noto Serif JP',serif;\">水</span><span style=\"position:absolute;bottom:1px;left:1px;font-size:6px;color:$3;opacity:.18;font-family:'Noto Serif JP',serif;\">土</span><span style=\"position:absolute;top:1px;left:1px;font-size:6px;color:$3;opacity:.18;font-family:'Noto Serif JP',serif;\">雷</span><div style=\"position:absolute;inset:0;border-radius:50%;overflow:hidden;border:1.5px solid $3;background:#0c0e14;display:flex;align-items:center;justify-content:center;box-shadow:0 0 20px -4px $3,0 0 40px -10px $3;\"><div style=\"position:absolute;inset:0;display:flex;align-items:center;justify-content:center;\"><svg viewBox='0 0 24 24' width='28' height='28' fill='none' stroke='$3' stroke-width='1.3' opacity='.75'><circle cx='12' cy='8.4' r='3.7'/><path d='M5 20a7 7 0 0 1 14 0'/></svg></div><img src=\"https://files.catbox.moe/$1\" alt=\"$2\" style=\"position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;background:#0c0e14;\" onerror=\"this.style.display='none'\"/></div></div></div><div style=\"display:flex;flex-direction:column;justify-content:center;gap:4px;min-width:0;flex:1;\"><span style=\"font-size:15px;font-weight:700;color:#e8e4dc;letter-spacing:1.5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">$2</span><span style=\"font-family:'M PLUS 1',sans-serif;font-size:7px;letter-spacing:2px;color:$3;opacity:.6;text-transform:uppercase;\">$4 · $5</span></div></div><div style=\"height:1px;margin-top:10px;background:$3;opacity:.5;\"></div></div>",
    "trimStrings": [],
    "placement": [
        1,
        2
    ],
