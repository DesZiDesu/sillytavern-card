    "replaceString": "<link href=\"https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@500;700;800&family=Noto+Serif+JP:wght@500;700;900&family=Noto+Serif+Thai:wght@500;700&family=M+PLUS+1:wght@400;600;700&display=swap\" rel=\"stylesheet\"/><div style=\"max-width:470px;margin:6px auto 14px;font-family:'Shippori Mincho','Noto Serif JP','Noto Serif Thai',serif;\"><div style=\"position:relative;padding:14px 18px;background:rgba(14,14,22,.6);color:#dcd8d0;font-size:13.5px;line-height:1.65;border:1px solid rgba(255,255,255,.06);border-radius:4px;box-shadow:0 4px 14px rgba(0,0,0,.4),0 0 12px -4px $1;\"><span style=\"position:absolute;top:-2px;left:-2px;width:14px;height:14px;border-top:2px solid $1;border-left:2px solid $1;border-radius:3px 0 0 0;\"></span><span style=\"position:absolute;top:-2px;right:-2px;width:14px;height:14px;border-top:2px solid $1;border-right:2px solid $1;border-radius:0 3px 0 0;\"></span><span style=\"position:absolute;bottom:-2px;left:-2px;width:14px;height:14px;border-bottom:2px solid $1;border-left:2px solid $1;border-radius:0 0 0 3px;\"></span><span style=\"position:absolute;bottom:-2px;right:-2px;width:14px;height:14px;border-bottom:2px solid $1;border-right:2px solid $1;border-radius:0 0 3px 0;\"></span>$2</div></div>",
    "trimStrings": [],
    "placement": [
        1,
        2
    ],
