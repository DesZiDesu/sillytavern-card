    "findRegex": "/\\[TRACK\\|(.*?)\\|(.*?)\\|(.*?)\\|(.*?)\\|(.*?)\\|(.*?)\\|(.*?)\\|(.*?)\\]/g",
    "replaceString": "<div style=\"max-width:520px;margin:0 auto 16px auto;background:#000000;border:1px solid #262626;color:#e8e8e8;font-family:'Inter','Helvetica Neue',Arial,sans-serif;line-height:1.5;\">\n  <div style=\"height:2px;background:linear-gradient(90deg,#c9a961,#6e5a2e 55%,transparent);\"></div>\n  <div style=\"padding:13px 18px 11px;display:flex;justify-content:space-between;align-items:flex-end;border-bottom:1px solid #1a1a1a;\">\n    <div style=\"min-width:0;\">\n      <div style=\"font-size:9px;letter-spacing:3px;color:#c9a961;text-transform:uppercase;font-weight:700;\">Field Log</div>\n      <div style=\"font-size:11px;color:#7a7a7a;letter-spacing:1px;margin-top:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">$1 &middot; $2</div>\n    </div>\n    <div style=\"font-size:22px;color:#ffffff;font-weight:600;letter-spacing:1px;font-variant-numeric:tabular-nums;line-height:1;flex-shrink:0;padding-left:12px;\">$5</div>\n  </div>\n  <div style=\"padding:11px 18px;text-align:center;border-bottom:1px solid #1a1a1a;\">\n    <span style=\"font-size:12px;color:#ffffff;letter-spacing:1.5px;text-transform:uppercase;font-weight:500;\">$6</span>\n  </div>\n  <div style=\"display:grid;grid-template-columns:1fr 1fr;border-bottom:1px solid #1a1a1a;\">\n    <div style=\"padding:11px 18px;border-right:1px solid #1a1a1a;\">\n      <div style=\"font-size:9px;letter-spacing:2px;color:#6e6e6e;text-transform:uppercase;font-weight:600;margin-bottom:5px;\">Weather</div>\n      <div style=\"font-size:13px;color:#ffffff;\">$3</div>\n    </div>\n    <div style=\"padding:11px 18px;\">\n      <div style=\"font-size:9px;letter-spacing:2px;color:#6e6e6e;text-transform:uppercase;font-weight:600;margin-bottom:5px;\">Temp</div>\n      <div style=\"font-size:13px;color:#ffffff;font-variant-numeric:tabular-nums;\">$4</div>\n    </div>\n  </div>\n  <div style=\"padding:12px 18px;border-bottom:1px solid #1a1a1a;\">\n    <div style=\"font-size:9px;letter-spacing:2px;color:#6e6e6e;text-transform:uppercase;font-weight:600;margin-bottom:6px;\">Position</div>\n    <div style=\"font-size:13px;color:#e8e8e8;line-height:1.55;\">$7</div>\n  </div>\n  <div style=\"padding:12px 18px;\">\n    <div style=\"font-size:9px;letter-spacing:2px;color:#6e6e6e;text-transform:uppercase;font-weight:600;margin-bottom:6px;\">Situation</div>\n    <div style=\"font-size:13px;color:#e8e8e8;line-height:1.55;\">$8</div>\n  </div>\n</div>",
    "trimStrings": [],
    "placement": [
        1,
        2
    ],
